  "guide": {
    "title": "Killio-Scripts",
    "description": "Cómo fluye la lógica dentro del script y cómo usar regex, remaps y acciones.",
    "yes": "sí",
    "no": "no",
    "steps": {
      "trigger": {
        "title": "1. El trigger emite items",
        "body": "Cada trigger crea uno o varios items. Un item es un objeto JSON con datos como todoText, filePath, branch, commitSha o cualquier payload manual."
      },
      "regex": {
        "title": "2. Regex Match decide la rama",
        "body": "El nodo Regex Match lee un campo de item.data, por ejemplo todoText o filePath, ejecuta un patrón y marca __matched=true o false.",
        "exampleField": "field: todoText",
        "examplePattern": "pattern: fix|urgent|bug",
        "exampleOutput": "salida: match_true o match_false",
        "footer": "Usa el handle match_true para la ruta positiva y match_false para el resto."
      },
      "map": {
        "title": "3. JSON remap reorganiza el item",
        "body": "JSON Map copia valores de una ruta a otra. Puedes mapear desde $.todoText o desde otra ruta anidada para preparar datos antes de una acción.",
        "exampleTarget": "targetPath: card.payload.title",
        "exampleSource": "sourcePath: todoText"
      },
      "template": {
        "title": "4. Template crea texto derivado",
        "body": "El nodo Template escribe texto usando placeholders. Soporta rutas con llaves, por ejemplo {todoText} o {repoFullName}.",
        "exampleTemplate": "template: TODO {todoText} en {filePath}",
        "exampleTarget": "targetPath: summary.generated"
      },
      "action": {
        "title": "5. La acción consume el item",
        "body": "Las acciones Create/Update/Move/Assign usan el item transformado. Si llegas con un título o payload ya remapeado, la acción lo toma desde item.data."
      }
    },
