  "guide": {
    "title": "Killio-Scripts",
    "description": "How logic flows through the script and how to use regex, remaps, and actions.",
    "yes": "yes",
    "no": "no",
    "steps": {
      "trigger": {
        "title": "1. Trigger emits items",
        "body": "Each trigger creates one or more items. An item is a JSON object with data such as todoText, filePath, branch, commitSha, or any manual payload."
      },
      "regex": {
        "title": "2. Regex Match chooses the branch",
        "body": "The Regex Match node reads a field from item.data, for example todoText or filePath, runs a pattern, and sets __matched=true or false.",
        "exampleField": "field: todoText",
        "examplePattern": "pattern: fix|urgent|bug",
        "exampleOutput": "output: match_true or match_false",
        "footer": "Use the match_true handle for the positive path and match_false for the rest."
      },
      "map": {
        "title": "3. JSON remap reshapes the item",
        "body": "JSON Map copies values from one path to another. You can map from $.todoText or another nested path to prepare data before an action.",
        "exampleTarget": "targetPath: card.payload.title",
        "exampleSource": "sourcePath: todoText"
      },
      "template": {
        "title": "4. Template generates derived text",
        "body": "The Template node writes text using placeholders. It supports braced paths, such as {todoText} or {repoFullName}.",
        "exampleTemplate": "template: TODO {todoText} in {filePath}",
        "exampleTarget": "targetPath: summary.generated"
      },
      "action": {
        "title": "5. Action consumes the item",
        "body": "Create/Update/Move/Assign actions use the transformed item. If you already mapped a title or payload, the action reads it from item.data."
      }
    },
    "summary": {
      "title": "Quick read of current graph",
      "regex": "Regex Match present: {{value}}",
      "jsonMap": "JSON Map present: {{value}}",
      "template": "Template present: {{value}}",
