# Killio Frontend – Environment Variables
# Copy this file to `.env.local` and fill in your credentials.

# ──────────────────────────────────────────────
# Backend API
# ──────────────────────────────────────────────
# Preferred
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# Backward compatible alias (optional)
NEXT_PUBLIC_API_URL=http://localhost:4000

# Optional alias supported by integrations/scripts API clients
NEXT_PUBLIC_KILLIO_API_URL=http://localhost:4000

# GitHub App setup tip:
# In your GitHub App settings, set Setup URL to:
# http://localhost:3000/integrations
# (or your production frontend URL + /integrations)

# ──────────────────────────────────────────────
# Ably – realtime WebSocket transport
# Get keys from https://ably.com
NEXT_PUBLIC_ABLY_AUTH_URL=/api/ably-auth   # Proxy through Next.js API route
ABLY_API_KEY=7N4yjg.6i_OBw:W1s0NyFHtmCEjIB1RxmMwYWtJL7rWlE-V7BPp1DHOhE      # Server-side only (used by the proxy)

# ──────────────────────────────────────────────
# Cohere AI  (server-side proxy – never expose to browser)
COHERE_API_KEY=IqdburzvF8XP7ctIdHS1Yhsvxi4Z23UtbbF1P0b3

# ──────────────────────────────────────────────
# MyScript iinkTS – handwriting recognition (pen mode)
# Get keys from https://developer.myscript.com
MYSCRIPT_APP_KEY=your_app_key_here
MYSCRIPT_HMAC_KEY=your_hmac_key_here
